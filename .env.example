# ─── Admin credentials ────────────────────────────────────────────────────────
ADMIN_USER=admin
# Generate a bcrypt hash with: node scripts/hash-password.js yourpassword
# Then paste the output here. Leave blank to fall back to ADMIN_PASS (plaintext).
ADMIN_PASS_HASH=
# Only used if ADMIN_PASS_HASH is not set (dev/migration convenience)
ADMIN_PASS=hemligt

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (used in Docker / production)
DATABASE_URL=postgres://flightclaim:changeme@db:5432/flightclaim
# Password for the PostgreSQL user — must match DATABASE_URL
DB_PASS=changeme

# ─── Company details (appear in generated PDFs) ───────────────────────────────
COMPANY_NAME=FlightClaim AB
COMPANY_REG=556677-8899
COMPANY_ADDRESS=Storgatan 1, 123 45 Stockholm

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Leave SMTP_HOST blank to disable email notifications entirely.
# Works with any SMTP provider (Gmail, Brevo, Mailgun, Postfix, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Set to true only for port 465 (implicit TLS), false for STARTTLS (587)
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=yourpassword
# The From address shown in sent emails
SMTP_FROM=FlightClaim <noreply@example.com>
# Admin inbox that receives a notification for every new claim
NOTIFY_EMAIL=admin@example.com

# ─── Application ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
