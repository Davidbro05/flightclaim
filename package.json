{
  "name": "flightclaim",
  "version": "2.0.1",
  "description": "Flight compensation claim management — EU Regulation 261/2004",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --exec \"ts-node --transpile-only src/server.ts\" --watch src --ext ts",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "hash-password": "node scripts/hash-password.js",
    "build:client": "cd client && npm ci && npm run build",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "basic-auth": "^2.0.1",
    "bcryptjs": "^2.4.3",
    "body-parser": "^2.2.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "knex": "^3.1.0",
    "marked": "^14.1.4",
    "nodemailer": "^8.0.4",
    "pdfkit": "^0.16.0",
    "pg": "^8.13.0",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0"
  },
  "devDependencies": {
    "@types/basic-auth": "^1.1.8",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.5",
    "jest": "^30.3.0",
    "nodemon": "^3.1.9",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
