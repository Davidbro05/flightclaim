<% scripts = '<script src="https://cdn.jsdelivr.net/npm/signature_pad@4.2.0/dist/signature_pad.umd.min.js"></script><script src="/js/claim-form.js?v=' + assetVersion + '"></script><script>(function(){var p=new URLSearchParams(location.search);var d=p.get("dep"),a=p.get("arr");if(d){var df=document.querySelector("[name=departureAirport]");if(df)df.value=d;}if(a){var af=document.querySelector("[name=arrivalAirport]");if(af)af.value=a;}})();</script>' %>

<!-- Page Hero -->
<section class="page-hero">
  <div class="container">
    <h1>Ansök om ersättning — kostnadsfritt</h1>
    <p>Fyll i formuläret nedan. Det tar ca 2 minuter och vi kontaktar dig inom 24 timmar.</p>
  </div>
</section>

<!-- Claim Form -->
<section class="form-section" style="padding: 60px 0;">
  <div class="container">
    <div class="form-container">
      <form action="/submit" method="POST" id="claimForm">
        <!-- Passenger Information -->
        <div class="form-panel">
          <h3><span class="panel-icon">👤</span> Passagerarinformation</h3>
          <div class="form-grid">
            <div class="form-group full-width">
              <label>Fullständigt namn</label>
              <input type="text" name="namn" required placeholder="Som det står i ditt pass">
            </div>
            <div class="form-group full-width">
              <label>Gatuadress</label>
              <input type="text" name="street" required placeholder="Gata och nummer">
            </div>
            <div class="form-group">
              <label>Postnummer</label>
              <input type="text" name="zip" required placeholder="12345">
            </div>
            <div class="form-group">
              <label>Ort</label>
              <input type="text" name="city" required placeholder="Stockholm">
            </div>
            <div class="form-group">
              <label>E-post</label>
              <input type="email" name="email" required placeholder="din.email@exempel.se">
            </div>
            <div class="form-group">
              <label>Telefon</label>
              <input type="tel" name="phone" required placeholder="070-123 45 67">
            </div>
          </div>
        </div>

        <!-- Flight Information -->
        <div class="form-panel">
          <h3><span class="panel-icon">✈️</span> Flyginformation</h3>
          <div class="form-grid">
            <div class="form-group">
              <label>Flygbolag</label>
              <input type="text" name="airline" required placeholder="t.ex. SAS, Norwegian">
            </div>
            <div class="form-group">
              <label>Flygnummer</label>
              <input type="text" name="flightNumber" required placeholder="t.ex. SK1234">
            </div>
            <div class="form-group">
              <label>Bokningsreferens (PNR)</label>
              <input type="text" name="bookingReference" placeholder="Valfritt">
            </div>
            <div class="form-group">
              <label>Avgångsflygplats</label>
              <div class="form-airport-wrap">
                <input type="text" name="departureAirport" id="form-dep-input" required placeholder="Stad eller IATA-kod, t.ex. ARN" autocomplete="off">
                <div id="form-dep-drop" class="airport-dropdown"></div>
              </div>
            </div>
            <div class="form-group">
              <label>Landningsflygplats</label>
              <div class="form-airport-wrap">
                <input type="text" name="arrivalAirport" id="form-arr-input" required placeholder="Stad eller IATA-kod, t.ex. LHR" autocomplete="off">
                <div id="form-arr-drop" class="airport-dropdown"></div>
              </div>
            </div>
            <div class="form-group">
              <label>Flygdatum</label>
              <input type="date" name="flightDate" required>
            </div>
            <div class="form-group full-width">
              <label>Vad hände?</label>
              <select name="issue" id="issueSelect" required>
                <option value="" disabled selected>Välj typ av störning</option>
                <option value="delay">Försening över 3 timmar</option>
                <option value="cancelled">Inställt flyg</option>
                <option value="denied">Nekad ombordstigning (overbooking)</option>
                <option value="rebooked">Ombokning / ändrad resväg utan info</option>
              </select>
            </div>
          </div>

          <!-- Extra fields shown only for rebooked -->
          <div id="rebooked-fields" style="display:none;">
            <div class="rebooked-info-box">
              <strong>EU-förordning 261/2004</strong> skyddar dig även när ett EU-registrerat flygbolag (t.ex. KLM, SAS, Lufthansa) ändrar din resväg utan att meddela dig i förväg — även på flyg utanför Europa. Du kan ha rätt till upp till <strong>600 € per person</strong>.
            </div>
            <div class="form-grid" style="margin-top: 16px;">
              <div class="form-group full-width">
                <label>Original resväg</label>
                <input type="text" name="original_route" id="originalRoute" placeholder="t.ex. ARN – AMS – NRT">
              </div>
              <div class="form-group full-width">
                <label>Ny resväg efter ändringen</label>
                <input type="text" name="new_route" id="newRoute" placeholder="t.ex. ARN – AMS – ICN – NRT">
              </div>
              <div class="form-group full-width">
                <label>När fick du veta om ändringen?</label>
                <select name="change_notice" id="changeNotice">
                  <option value="" disabled selected>Välj alternativ</option>
                  <option value="never">Aldrig / Fick veta vid incheckning</option>
                  <option value="less7">Mindre än 7 dagar innan avgång</option>
                  <option value="7to14">7–14 dagar innan avgång</option>
                  <option value="more14">Mer än 14 dagar innan avgång</option>
                </select>
              </div>
            </div>
          </div>
        </div>

        <!-- Legal & Signature -->
        <div class="form-panel">
          <h3><span class="panel-icon">⚖️</span> Juridiskt godkännande</h3>
          <div class="terms-box">
            <p><strong>Fullmakt</strong></p>
            <p>Genom att skriva under ger du FlightClaim AB i uppdrag att företräda dig i ersättningsärendet mot flygbolaget enligt EU-förordning 261/2004. Läs våra <a href="#" id="showTermsLink">fullständiga villkor</a>.</p>
          </div>
          <div class="checkbox-wrapper">
            <input type="checkbox" name="terms_accepted" id="termsAccepted" required>
            <label for="termsAccepted">Jag bekräftar att jag har läst och godkänner <a href="#" id="showTermsLinkInline">användarvillkoren</a> samt att uppgifterna ovan är korrekta.</label>
          </div>
          <div class="signature-area">
            <div class="signature-label">
              <label>Signatur</label>
              <span class="signature-hint">Rita med fingret eller musen</span>
            </div>
            <div class="signature-pad-container">
              <canvas id="signature-pad" class="signature-canvas" width="500" height="200"></canvas>
            </div>
            <button type="button" id="clear-signature" class="btn-secondary btn-small">Rensa signatur</button>
            <input type="hidden" name="signature" id="signature-input">
          </div>
        </div>

        <div class="form-footer">
          <p class="privacy-note">🔒 Dina uppgifter hanteras säkert enligt GDPR.</p>
          <button type="submit" class="btn-primary btn-large">Skicka ansökan – kostnadsfritt</button>
        </div>
      </form>
    </div>
  </div>
</section>

<!-- Terms Modal -->
<div id="termsModal" class="modal">
  <div class="modal-content">
    <span class="close">&times;</span>
    <h2>Användarvillkor för FlightClaim AB</h2>
    <div class="modal-body">
      <h3>Fullmakt och uppdragsbeskrivning</h3>
      <p>Härmed ger jag, undertecknad, FlightClaim AB (org.nr 559999-1234) i uppdrag att företräda mig i ärendet gällande ersättning från flygbolaget enligt EU-förordning 261/2004.</p>
      <h4>FlightClaim AB bemyndigas att:</h4>
      <ul>
        <li>Inhämta alla nödvändiga uppgifter från flygbolaget</li>
        <li>Föra min talan i kontakt med flygbolaget och eventuella tillsynsmyndigheter</li>
        <li>Vid behov vidta rättsliga åtgärder i mitt namn</li>
        <li>Ta emot ersättningsbetalningar på mina vägnar</li>
      </ul>
      <h4>Arvode</h4>
      <p>Vid framgångsrikt ärende utgår ett arvode om 25% + moms av den totala ersättningen. Inget arvode utgår om ärendet inte vinner framgång.</p>
      <h4>Personuppgifter</h4>
      <p>Personuppgifter behandlas i enlighet med vår integritetspolicy och GDPR.</p>
      <p><em>Genom att kryssa i rutan och signera bekräftar jag att jag har läst, förstått och godkänt dessa villkor.</em></p>
    </div>
  </div>
</div>
