<% /* Inject schema JSON-LD via the layout's `scripts` slot */ %>
<% scripts = `<script type="application/ld+json">${schemaJson}</script>` %>

<!-- Breadcrumb -->
<% if (crumbs && crumbs.length > 1) { %>
<div class="container" style="padding-top:20px;">
  <nav class="breadcrumb" aria-label="Brödsmulor">
    <% crumbs.forEach((c, i) => { %>
      <% if (i < crumbs.length - 1) { %>
        <a href="<%= c.url %>"><%= c.name %></a>
        <span class="sep" aria-hidden="true">›</span>
      <% } else { %>
        <span><%= c.name %></span>
      <% } %>
    <% }) %>
  </nav>
</div>
<% } %>

<!-- Article layout -->
<div class="container">
  <div class="article-layout">

    <!-- Main content -->
    <article class="article-body">
      <h1><%= article.title %></h1>

      <% if (typeof updatedAtLabel !== 'undefined' && updatedAtLabel) { %>
      <div class="article-meta">
        <% if (typeof author !== 'undefined' && author) { %>
        <span class="article-meta-item">Av <a href="/forfattare/<%= author.slug %>" class="article-author-link" rel="author"><%= author.name %></a></span>
        <span class="article-meta-sep" aria-hidden="true">·</span>
        <% } %>
        <span class="article-meta-item">Senast uppdaterad: <time datetime="<%= article.updated_at ?? article.created_at %>"><%= updatedAtLabel %></time></span>
        <% if (typeof readMin !== 'undefined' && readMin) { %>
        <span class="article-meta-sep" aria-hidden="true">·</span>
        <span class="article-meta-item"><%= readMin %> min läsning</span>
        <% } %>
      </div>
      <% } %>

      <% if (typeof toc !== 'undefined' && toc) { %>
      <nav class="article-toc" aria-label="Innehåll">
        <p class="article-toc-title">Innehåll</p>
        <ol>
          <% toc.forEach(function(t){ %>
          <li><a href="#<%= t.id %>"><%= t.text %></a></li>
          <% }) %>
        </ol>
      </nav>
      <% } %>

      <%- bodyHtml %>

      <!-- FAQ section -->
      <% if (faqItems && faqItems.length > 0) { %>
      <section class="article-faq">
        <h2>Vanliga frågor</h2>
        <% faqItems.forEach(f => { %>
        <details class="faq-item">
          <summary class="faq-question"><%= f.q %></summary>
          <div class="faq-answer"><%= f.a %></div>
        </details>
        <% }) %>
      </section>
      <% } %>

      <!-- Bottom CTA banner -->
      <div class="cta-banner">
        <h2>Drabbad av försenat eller inställt flyg?</h2>
        <p>Ansök om ersättning på 2 minuter — vi sköter hela processen mot flygbolaget.</p>
        <a href="/anmalan" class="btn-cta">Ansök om ersättning →</a>
      </div>
    </article>

    <!-- Sidebar -->
    <aside class="article-sidebar">
      <div class="cta-box">
        <h3>Få upp till 600€ i ersättning</h3>
        <p>Vi sköter hela processen mot flygbolaget. Du betalar ingenting om vi inte lyckas.</p>
        <a href="/anmalan" class="btn-cta">Ansök nu — gratis</a>
      </div>

      <% if (relatedArticles && relatedArticles.length > 0) { %>
      <div class="related-articles">
        <h3>Relaterade artiklar</h3>
        <ul>
          <% relatedArticles.forEach(r => { %>
          <li><a href="/<%= r.slug %>"><%= r.title %></a></li>
          <% }) %>
        </ul>
      </div>
      <% } %>
    </aside>

  </div>
</div>

<!-- Sticky mobile CTA -->
<div class="article-sticky-cta" role="complementary" aria-label="Ansök om ersättning">
  <div class="article-sticky-cta-inner">
    <div class="article-sticky-cta-text">
      <strong>Drabbad?</strong> <span>Kolla gratis om du har rätt</span>
    </div>
    <a href="/anmalan" class="btn-cta article-sticky-cta-btn">Ansök →</a>
  </div>
</div>
