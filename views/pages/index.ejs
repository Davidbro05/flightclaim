<% scripts = '<script src="/js/hero.js?v=' + assetVersion + '"></script>' %>

<!-- Hero Section -->
<section class="hero">
  <div class="container">
    <div class="hero-card">
      <h1>Försenat eller inställt flyg?<br>Du kan ha rätt till upp till <span class="hero-amount">600&nbsp;€</span></h1>
      <p class="hero-subtitle">Vi sköter allt mot flygbolaget — du betalar ingenting om vi inte vinner.</p>

      <div class="hero-form-row">
        <input type="text" id="hero-departure" class="hero-input" placeholder="✈ Avgångsflygplats (t.ex. ARN)">
        <input type="text" id="hero-arrival"   class="hero-input" placeholder="✈ Destination (t.ex. LHR)">
        <button type="button" class="btn-primary hero-check-btn">Beräkna min ersättning</button>
      </div>

      <div class="hero-badges">
        <span class="hero-badge"><span>✓</span> 100% gratis att kontrollera</span>
        <span class="hero-badge hero-badge-highlight"><span>✓</span> Ingen avgift om vi förlorar</span>
        <span class="hero-badge"><span>✓</span> Flygningar upp till 3 år tillbaka</span>
        <span class="hero-badge"><span>🇸🇪</span> Svensk support</span>
      </div>
    </div>
  </div>
</section>

<!-- Qualifying situations -->
<section class="eligibility-section">
  <div class="container">
    <h2>Vad ger rätt till ersättning?</h2>
    <p class="section-sub">EU-förordning 261/2004 ger passagerare rätt till 250–600&nbsp;€ i dessa situationer:</p>
    <div class="eligibility-grid">
      <div class="eligibility-card">
        <div class="eli-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3>Försening 3+ timmar</h3>
        <p>Anlände du mer än 3 timmar sent till din slutdestination?</p>
        <span class="eli-amount">250–600 €</span>
      </div>
      <div class="eligibility-card">
        <div class="eli-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        </div>
        <h3>Inställt flyg</h3>
        <p>Ställdes ditt flyg in med kort varsel — under 14 dagar?</p>
        <span class="eli-amount">250–600 €</span>
      </div>
      <div class="eligibility-card">
        <div class="eli-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="17" y1="11" x2="23" y2="11"/></svg>
        </div>
        <h3>Nekad ombordstigning</h3>
        <p>Nekades du boarding trots giltig biljett och incheckning?</p>
        <span class="eli-amount">250–600 €</span>
      </div>
      <div class="eligibility-card">
        <div class="eli-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
        </div>
        <h3>Ombokning utan info</h3>
        <p>Ombokades du till annan rutt eller tid utan ditt samtycke?</p>
        <span class="eli-amount">250–600 €</span>
      </div>
    </div>
    <div style="text-align:center; margin-top:36px;">
      <a href="/berakna-ersattning" class="btn-primary">Beräkna din ersättning gratis →</a>
    </div>
  </div>
</section>

<!-- Zero-risk section -->
<section class="zero-risk-section">
  <div class="container">
    <div class="zero-risk-inner">
      <div class="zero-risk-text">
        <h2>Du betalar ingenting om vi förlorar</h2>
        <p>Vi arbetar på provisionsbasis — vi tar bara betalt om du faktiskt får din ersättning. Ingen förskottsavgift, inga dolda kostnader.</p>
        <ul class="zero-risk-list">
          <li>Gratis initial kontroll av ditt ärende</li>
          <li>Vi driver ärendet mot flygbolaget på egna resurser</li>
          <li>Du får 75&nbsp;% av ersättningen — vi tar 25&nbsp;%</li>
          <li>Vinner vi ingenting betalar du ingenting</li>
        </ul>
        <a href="/anmalan" class="btn-cta" style="margin-top:24px; display:inline-block;">Ansök kostnadsfritt →</a>
      </div>
      <div class="zero-risk-visual">
        <div class="zero-risk-box">
          <div class="zr-label">Om vi förlorar betalar du</div>
          <div class="zr-amount">0 kr</div>
          <div class="zr-sub">Ingen risk. Inga dolda avgifter.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Why choose us -->
<section class="why-section">
  <div class="container">
    <h2>Varför välja FlightClaim?</h2>
    <div class="why-grid">
      <div class="why-item">
        <div class="why-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 3.5A9.97 9.97 0 0 1 12 3c5.52 0 10 4.48 10 9"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <h3>Svensk support</h3>
        <p>Vi kommunicerar på svenska och svarar inom 24 timmar. Inga callcenter utomlands.</p>
      </div>
      <div class="why-item">
        <div class="why-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
        </div>
        <h3>Inga dolda avgifter</h3>
        <p>25&nbsp;% provision vid utbetalning — det är allt. Ingen startavgift, inga administrativa kostnader.</p>
      </div>
      <div class="why-item">
        <div class="why-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>EU261-specialister</h3>
        <p>Vi känner regelverket utan och innan och driver ärendet hela vägen — även till domstol vid behov.</p>
      </div>
      <div class="why-item">
        <div class="why-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <h3>Upp till 3 år tillbaka</h3>
        <p>Preskriptionstiden är 3 år. Äldre ärenden kan fortfarande drivas — kolla ditt flyg nu.</p>
      </div>
    </div>
  </div>
</section>

<!-- How It Works -->
<section id="how-it-works" class="how-it-works">
  <div class="container">
    <h2>Så här enkelt är det</h2>
    <div class="steps">
      <%- include('../components/step-card', { stepNumber: '1', stepTitle: 'Fyll i formuläret', stepText: 'Ange dina uppgifter och flyginformation – det tar bara 2 minuter.' }) %>
      <%- include('../components/step-card', { stepNumber: '2', stepTitle: 'Vi granskar ditt ärende', stepText: 'Våra juridiska experter bedömer dina chanser och inleder processen.' }) %>
      <%- include('../components/step-card', { stepNumber: '3', stepTitle: 'Du får din ersättning', stepText: 'Vi driver ärendet mot flygbolaget. Pengarna betalas ut direkt till dig.' }) %>
    </div>
    <div style="text-align:center; margin-top:32px;">
      <a href="/sa-fungerar-det" class="btn-secondary">Läs mer om processen →</a>
    </div>
  </div>
</section>

<!-- Testimonials -->
<section class="testimonials">
  <div class="container">
    <h2>Vad våra kunder säger</h2>
    <div class="testimonial-grid">
      <%- include('../components/testimonial', { stars: '★★★★★', quote: 'Enkel process och tydlig kommunikation. Skönt att någon annan sköter kontakten med flygbolaget.', author: 'Anna', city: 'Stockholm' }) %>
      <%- include('../components/testimonial', { stars: '★★★★★', quote: 'Professionellt intryck från start. Hoppas på positivt besked från flygbolaget snart!', author: 'Johan', city: 'Göteborg' }) %>
      <%- include('../components/testimonial', { stars: '★★★★☆', quote: 'Bra och tydlig återkoppling. Ser fram emot att följa mitt ärende.', author: 'Maria', city: 'Malmö' }) %>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="faq">
  <div class="container">
    <h2>Vanliga frågor</h2>
    <div class="faq-grid">
      <%- include('../components/faq-item', { faqQuestion: 'Vad kostar det?', faqAnswer: 'Det kostar ingenting att ansöka eller kontrollera. Vi tar 25 % provision på utbetald ersättning — vinner vi ingenting betalar du ingenting.' }) %>
      <%- include('../components/faq-item', { faqQuestion: 'Vilka flygningar gäller?', faqAnswer: 'Alla flygningar inom EU samt flygningar till/från EU med EU-baserade flygbolag. Preskriptionstiden är 3 år, så äldre ärenden kan fortfarande drivas.' }) %>
      <%- include('../components/faq-item', { faqQuestion: 'Hur lång tid tar det?', faqAnswer: 'De flesta ärenden löses inom 4–8 veckor. Komplicerade fall som kräver rättslig prövning kan ta längre tid — vi håller dig uppdaterad längs vägen.' }) %>
      <%- include('../components/faq-item', { faqQuestion: 'Vad behöver jag skicka in?', faqAnswer: 'Bokningsbekräftelse och, om du har kvar det, boardingkortet. Vi guidar dig genom hela processen steg för steg.' }) %>
    </div>
    <div style="text-align:center; margin-top:28px;">
      <a href="/sa-fungerar-det#faq" class="btn-secondary">Se alla frågor →</a>
    </div>
  </div>
</section>
