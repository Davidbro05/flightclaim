<% scripts = '<script src="/js/hero.js?v=' + assetVersion + '"></script>' %>

<!-- Hero Section — full-bleed photo + wide frosted card anchored to bottom -->
<section class="hero">
  <div class="container">
    <div class="hero-card">
      <h1>Ansök om ersättning för ditt flyg</h1>
      <p class="hero-subtitle">Drabbad av försening, inställt flyg eller nekad ombordstigning? Du kan ha rätt till upp till 600€ per person.</p>

      <div class="hero-form-row">
        <input type="text" id="hero-departure" class="hero-input" placeholder="✈ Avgångsflygplats (t.ex. ARN)">
        <input type="text" id="hero-arrival" class="hero-input" placeholder="✈ Destinationsflygplats (t.ex. LHR)">
        <button type="button" class="btn-primary hero-check-btn">Kontrollera din ersättning</button>
      </div>

      <div class="hero-badges">
        <span class="hero-badge"><span>✓</span> Gratis och enkel kontroll</span>
        <span class="hero-badge hero-badge-highlight"><span>🇸🇪</span> Svensk support</span>
        <span class="hero-badge"><span>✓</span> Flygningar upp till 3 år</span>
      </div>
    </div>
  </div>
</section>

<!-- How It Works — summary -->
<section id="how-it-works" class="how-it-works">
  <div class="container">
    <h2>Så här enkelt är det</h2>
    <div class="steps">
      <%- include('../components/step-card', { stepNumber: '1', stepTitle: 'Fyll i formuläret', stepText: 'Ange dina uppgifter och flyginformation – det tar bara 2 minuter.' }) %>
      <%- include('../components/step-card', { stepNumber: '2', stepTitle: 'Vi granskar ditt ärende', stepText: 'Våra juridiska experter bedömer dina chanser och inleder processen.' }) %>
      <%- include('../components/step-card', { stepNumber: '3', stepTitle: 'Du får din ersättning', stepText: 'Vi driver ärendet mot flygbolaget. Pengarna betalas ut direkt till dig.' }) %>
    </div>
    <div style="text-align:center; margin-top:32px;">
      <a href="/sa-fungerar-det" class="btn-secondary">Läs mer om processen →</a>
    </div>
  </div>
</section>

<!-- Testimonials -->
<section class="testimonials">
  <div class="container">
    <h2>Vad våra kunder säger</h2>
    <div class="testimonial-grid">
      <%- include('../components/testimonial', { stars: '★★★★★', quote: 'Enkel process och tydlig kommunikation. Skönt att någon annan sköter kontakten med flygbolaget.', author: 'Anna', city: 'Stockholm' }) %>
      <%- include('../components/testimonial', { stars: '★★★★★', quote: 'Professionellt intryck från start. Hoppas på positivt besked från flygbolaget snart!', author: 'Johan', city: 'Göteborg' }) %>
      <%- include('../components/testimonial', { stars: '★★★★☆', quote: 'Bra och tydlig återkoppling. Ser fram emot att följa mitt ärende.', author: 'Maria', city: 'Malmö' }) %>
    </div>
  </div>
</section>

<!-- About teaser -->
<section class="about-section">
  <div class="container">
    <h2>Om FlightClaim</h2>
    <div class="about-content">
      <div class="about-text">
        <p>FlightClaim har en enkel mission: att hjälpa resenärer att få den ersättning de har rätt till enligt EU-förordning 261/2004. Vi kombinerar gedigen juridisk expertis med modern teknik för att göra processen enkel och smidig.</p>
        <p>Vi tar endast betalt om du får din ersättning — ingen seger, ingen avgift.</p>
        <div style="margin-top:24px;">
          <a href="/om-oss" class="btn-secondary">Läs mer om oss →</a>
        </div>
      </div>
      <div class="about-stats">
        <div class="about-stat">
          <span class="about-number">Gedigen</span>
          <span class="about-label">erfarenhet</span>
        </div>
        <div class="about-stat">
          <span class="about-number">Juridisk</span>
          <span class="about-label">expertis</span>
        </div>
        <div class="about-stat">
          <span class="about-number">100%</span>
          <span class="about-label">Transparens</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FAQ (2 items) -->
<section class="faq">
  <div class="container">
    <h2>Vanliga frågor</h2>
    <div class="faq-grid">
      <%- include('../components/faq-item', { faqQuestion: 'Vad kostar det?', faqAnswer: 'Vi tar endast provision om vi vinner ditt ärende (25% + moms på ersättningen). Inga dolda avgifter.' }) %>
      <%- include('../components/faq-item', { faqQuestion: 'Vilka flygningar gäller?', faqAnswer: 'Alla flygningar inom EU, samt flygningar till/från EU med EU-baserade flygbolag.' }) %>
    </div>
    <div style="text-align:center; margin-top:28px;">
      <a href="/sa-fungerar-det#faq" class="btn-secondary">Se alla frågor →</a>
    </div>
  </div>
</section>

